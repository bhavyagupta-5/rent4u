# ==========================
# RentHour AI — Root .gitignore
# ==========================

# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example

# Node dependencies
node_modules/
**/node_modules/

# Build output
client/dist/
client/dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS junk
.DS_Store
Thumbs.db

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker (local volume data)
mongo-data/

# Coverage reports
coverage/

# Temporary files
*.tmp
