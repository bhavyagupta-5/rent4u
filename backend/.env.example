# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/renthour_ai?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_access_token_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_key_change_me

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Grok API (xAI)
GROK_API_KEY=your_xai_grok_api_key_here
GROK_MODEL=grok-4
GROK_BASE_URL=https://api.x.ai/v1

# Email Notifications (Nodemailer - e.g. Gmail App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Cloudinary configuration (File Uploads)
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret
